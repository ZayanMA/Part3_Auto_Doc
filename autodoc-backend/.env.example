# Copy this file to .env and fill in your values.
# IMPORTANT: If you have been using a real key locally, rotate it at https://openrouter.ai/keys

OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=stepfun/step-3.5-flash
OPENROUTER_APP_URL=http://localhost
OPENROUTER_APP_NAME=autodoc-backend
AUTODOC_API_KEY=your-api-server-key-here
